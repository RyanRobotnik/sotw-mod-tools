{
  "name": "sotw-mod-tools",
  "version": "1.0.0",
  "description": "Google Apps Script tools for Google Sheets. Used for managing the Screenshot of the Week competition on Arqade (Gaming Stack Exchange)",
  "license": "AGPL-3.0",
  "author": "RyanRobotnik",
  "repository": {
    "type": "git",
    "url": "https://github.com/RyanRobotnik/sotw-mod-tools.git"
  },
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "npm run clean && webpack",
    "push": "npm run build && clasp push",
    "push:version": "clasp deploy",
    "lint": "eslint './src/**/*.ts'",
    "lint:fix": "eslint './src/**/*.ts' --fix",
    "clasp:login": "clasp login",
    "clasp:open": "clasp open"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@google/clasp": "^3.3.0",
    "@types/google-apps-script": "^1.0.83",
    "@types/jest": "^29.5.12",
    "copy-webpack-plugin": "^14.0.0",
    "eslint": "^10.0.3",
    "eslint-plugin-googleappsscript": "^1.0.5",
    "gas-webpack-plugin": "^2.6.0",
    "globals": "^17.4.0",
    "ts-loader": "^9.5.4",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.57.1",
    "webpack": "^5.105.4",
    "webpack-cli": "^7.0.2"
  }
}